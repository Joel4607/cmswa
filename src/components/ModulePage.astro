---
import Layout from '../layouts/Layout.astro';
import DataTable from './DataTable.astro';
import { asMoney, sumMatchedColumns, MONTH_NAMES } from '../lib/format';
import { getDB, getGroupedRecords } from '../lib/db';

interface Props {
  module: string;
  title: string;
  totalKeys?: string[];
}
const { module, title, totalKeys = ['TOTAL'] } = Astro.props;
const db = getDB(Astro);
const records = await getGroupedRecords(db);
const mod = records[module] ?? {};
const years = Object.keys(mod).sort();
---
<Layout title={title}>
  <h1>{title}</h1>
  {years.length === 0 && <p class="muted">No records found.</p>}
  {years.map(year => (
    <div class="section">
      <h2>{year}</h2>
      {Object.entries(mod[year]).map(([file, sheets]: [string, any]) => (
        <div>
          {Object.entries(sheets).map(([sheetName, sheet]: [string, any]) => {
            const total = sumMatchedColumns(sheet.rows, sheet.headers, totalKeys);
            return (
              <div class="section">
                <h3 class="muted">{sheetName}
                  {total > 0 && <span style="float:right;color:var(--primary)">Total: GH₵ {asMoney(total)}</span>}
                </h3>
                <DataTable headers={sheet.headers} rows={sheet.rows} />
              </div>
            );
          })}
        </div>
      ))}
    </div>
  ))}
</Layout>
